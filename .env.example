# Supabase (replaces MongoDB)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

API_PORT=4000
PUBLIC_API_URL=http://localhost:4000

# Auth
JWT_SECRET=change_me_local_dev

# Gemini — primary LLM for AI pipeline (runs automatically after documents are uploaded)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# OpenAI — optional fallback for LLM agents
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Twilio — linked to ElevenLabs (also used for TTS fallback)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_FROM_NUMBER=

# ElevenLabs — agent outbound calls to applicant phone from visa apply
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
ELEVENLABS_PHONE_NUMBER_ID=
ELEVENLABS_WEBHOOK_SECRET=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
